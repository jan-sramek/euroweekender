{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "fileLogging": {
      "outputFile": "./log.txt",
      "maxFileSizeInMegabytes": 10,
      "rollOnFileSizeLimit": true
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "functions": [
    {
      "name": "WeekendFlightCrawler",
      "type": "Azure.Functions.Cron"
    }
  ],
  "hosting": {
    "durableFunctions": {
      "maxConcurrentInstances": 10
    },
    "httpWorkerOptions": {
      "routePrefix": ""
    },
    "workerRuntime": {
      "enableGrpcSupport": true,
      "grpcEndpoint": "localhost:5000"
    }
  }
}